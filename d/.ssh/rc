#!/bin/sh
# sshd runs this file at session start (before the user's shell).
# When agent forwarding is active, SSH_AUTH_SOCK is already set to the new
# socket. We create a stable symlink so existing shells (e.g. inside tmux)
# can always find the current agent without knowing the random socket path.
if [ -n "$SSH_AUTH_SOCK" ]; then
    mkdir -p "$HOME/.ssh"
    ln -sf "$SSH_AUTH_SOCK" "$HOME/.ssh/ssh_auth_sock"
    # Tell running tmux sessions to use the stable symlink so that
    # update_auth_sock picks it up in every pane on the next command.
    if command -v tmux >/dev/null 2>&1; then
        tmux list-sessions 2>/dev/null | cut -d: -f1 | while read -r s; do
            tmux setenv -t "$s" SSH_AUTH_SOCK "$HOME/.ssh/ssh_auth_sock"
        done
    fi
fi
